# AI Gita Mentor — environment variables (names only; fill real values in Railway).
# Copy to .env for local dev. NEVER commit a real .env.

# --- App ---
# Public marketing/KB origin (the `ai.` host). Used for sitemap/canonical and to
# detect which host should redirect gated paths to the app.
APP_BASE_URL=https://ai.applygitawisdom.com
# Gated app origin (the `app.` host) where auth, /app, /admin live. Public-site
# CTAs link here, and gated paths hit on `ai.` 308-redirect here.
#   production env : APP_URL=https://app.applygitawisdom.com
#   orbitq (staging): APP_URL=https://orbitq.app.applygitawisdom.com
# Leave empty for single-host local dev (no redirects).
APP_URL=
ENVIRONMENT=development
DEBUG=false
# Comma-separated emails auto-granted admin (access to /admin Knowledge Studio).
ADMIN_EMAILS=
# Temp dir for in-browser recordings before Drive copy (Section 6).
RECORDINGS_TMP_DIR=recordings_tmp

# --- Database (Railway Postgres + pgvector) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Secrets encryption (OPTIONAL) ---
# DB-stored secrets are always encrypted at rest. By default the key is derived
# from JWT_SECRET (which you already manage) — leave this BLANK and there's nothing
# extra to babysit. Only set a dedicated key (comma-separated NEW,OLD supported for
# rotation) if you want secrets to survive a JWT_SECRET rotation. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# NOTE: everything below (Google OAuth/Drive, Razorpay, Meta) is also editable at
# runtime in Admin → Settings · Integrations (encrypted, DB value overrides env).
# These env vars remain as the fallback for a fresh deploy before it's set once.

# --- Chat LLM / embeddings / baselines ---
# Keys can also be set (encrypted) at runtime in admin Settings → AI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
# Per-tier chat models (free → Haiku, paid → Sonnet) + admin/recorder/baseline model.
CHAT_MODEL_FREE=claude-haiku-4-5
CHAT_MODEL_PAID=claude-sonnet-5
CHAT_MODEL=claude-sonnet-5

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://ai.applygitawisdom.com/auth/google/callback

# --- Google Drive (audio archive) ---
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
DRIVE_RECORDINGS_FOLDER_ID=

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Subscription plan ids created in the Razorpay dashboard (monthly ₹499 / ₹1,459).
RAZORPAY_PLAN_ABHYASI=
RAZORPAY_PLAN_SADHAKA=

# --- Escalation (Chunk 5) ---
# The 1-on-1 booking link, assessment link, video-link lifetime and assessment
# fresh-window are managed in the admin panel (Escalation section), NOT via env.

# --- Analytics (Meta) ---
META_PIXEL_ID=
META_CAPI_TOKEN=
# Optional: while testing in Events Manager → Test Events, set the code here.
META_TEST_EVENT_CODE=
