# AI Gita Mentor — environment variables (names only; fill real values in Railway).
# Copy to .env for local dev. NEVER commit a real .env.

# --- App ---
APP_BASE_URL=https://ai.applygitawisdom.com
ENVIRONMENT=development
DEBUG=false

# --- Database (Railway Postgres + pgvector) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Chat LLM / embeddings / baselines ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://ai.applygitawisdom.com/auth/google/callback

# --- Google Drive (audio archive) ---
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
DRIVE_RECORDINGS_FOLDER_ID=

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Analytics (Meta) ---
META_PIXEL_ID=
META_CAPI_TOKEN=
